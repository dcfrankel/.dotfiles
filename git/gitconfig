[core]
  editor = vim
  whitespace = trailing-space

[branch]
  # Better sort for git branch
  sort = -committerdate

[tag]
  # Better sort for git tag
  sort = -version:refname

[commit]
  # Add the commit diff into the default commit message (useful for remembering what you did)
  verbose = true

[push]
  # Prevents the need to manually run git push --set-upstream origin my-branch-name
  autoSetupRemote = true
  # Makes sure to push local tags to the remote
  followTags = true

[pull]
  # Prevents the need for constantly setting --rebase
  rebase = true

[diff]
  # Newer diff algorithm with
  algorithm = histogram
  # Highlight if something moved vs if something was added or deleted
  coloMoved = plain
  # Show if something was renamed
  renames = true

[rebase]
 # Prevents the need for using --autosquash when rebasing
  autosquash = true

# Work specific configs
[includeIf "gitdir:~/work/"]
  path = ~/work/.gitconfig

# Personal configs
[includeIf "gitdir:~/Projects/"]
  path = ~/Projects/.gitconfig

# If in .dotfiles use project config
[includeIf "gitdir:~/.dotfiles/"]
  path = ~/Projects/.gitconfig

# If in .dotfiles use project config
[includeIf "gitdir:~/setup/"]
  path = ~/Projects/.gitconfig

[alias]
  plog = "!git log --graph --all --color=always --pretty=format:'%C(magenta)%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset'"
  create-remote = "!git push -u origin $(git branch --show-current)"
  patch = "!git add --patch"
  root = "!git rev-parse --show-toplevel"
  nuke = "!git reset HEAD --hard && git clean -fdx"
  # Find the default branch (requires there to be a github remote)
  default-branch = "!git remote show origin | sed -n '/HEAD branch/s/.*: //p'"
  # Move commits from a feature branch onto main (useful if the feature branch was based off of another feature branch)
  # Args: 1) get the default remote branch to use as the new base, 2) find the last common ancestor commit ie original base, 3) find current branch to move
  transplant = "!git rebase --onto $(git default-branch) $(git merge-base main HEAD) $(git rev-parse --abbrev-ref HEAD)"

[color "status"]
  added = green bold
  changed = red bold strike
  untracked = yellow bold
  branch = green bold ul

[help]
  autocorrect = prompt

[http]
  postBuffer = 524288000

[init]
  defaultBranch = main

[status]
  # Use short git status for my own sanity
  short = true
  branch = true

[merge]
  conflictStyle = zdiff3
