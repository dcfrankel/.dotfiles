# Note: Empty values reset the configuration to the default value
# Built in theme and related visual tweaks
theme = "Catppuccin Macchiato"

# Font related settings
font-family = "Hack Nerd Font"
font-size = 14
font-feature = -liga
font-thicken = true
adjust-cell-height = 1

working-directory = home
# Don't inherit another tab or windows directory
window-inherit-working-directory = false
tab-inherit-working-directory = false
split-inherit-working-directory = true

# SSH related configs
# Fixes issues with the terminfo xterm-ghostty value not existing on older systems
shell-integration-features = ssh-env,no-cursor

cursor-style-blink = true
cursor-style = block
