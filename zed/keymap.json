// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    // We need to exlude the terminal otherwise it causes input delay
    "context": "(Dock || EmptyPane || vim_mode == normal || vim_mode == visual) && !Terminal",
    "bindings": {
      // Additional pane jumping motions
      "space h": "workspace::ActivatePaneLeft",
      "space l": "workspace::ActivatePaneRight",
      "space k": "workspace::ActivatePaneUp",
      "space j": "workspace::ActivatePaneDown",
    },
  },
  {
    "context": "vim_mode == normal || vim_mode == visual",
    "bindings": {
      // Add support for helix word jumping
      "g w": "vim::HelixJumpToWord",
      // Open lazygit from task
      // Note: This needs to stay under the vim context otherwise it causes odd input delays follow space press
      "space l g": [
        "task::Spawn",
        { "task_name": "LazyGit", "reveal_target": "center" },
      ],
    },
  },
  // Add normal tab switching bindings for mac
  {
    "context": "Pane",
    "bindings": {
      "cmd-1": ["pane::ActivateItem", 0],
      "cmd-2": ["pane::ActivateItem", 1],
      "cmd-3": ["pane::ActivateItem", 2],
      "cmd-4": ["pane::ActivateItem", 3],
      "cmd-5": ["pane::ActivateItem", 4],
      "cmd-6": ["pane::ActivateItem", 5],
      "cmd-7": ["pane::ActivateItem", 6],
      "cmd-8": ["pane::ActivateItem", 7],
      "cmd-9": ["pane::ActivateItem", 8],
    },
  },
]
